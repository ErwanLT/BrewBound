# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_TOKEN: Required to create Pull Requests automatically.
# Create a classic token with 'repo' scope at https://github.com/settings/tokens
GITHUB_TOKEN=""

# Repository information (where the code is hosted)
GITHUB_REPO_OWNER=""
GITHUB_REPO_NAME=""
